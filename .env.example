# =============================================================
# Docker Production App — Environment Variables TEMPLATE
# Copy this file to .env and fill in real values
# This file IS committed to git (no real secrets here)
# =============================================================

APP_NAME=docker-production-app
APP_ENV=development
APP_VERSION=1.0.0

NODE_ENV=development
BACKEND_PORT=5000

API_PORT=8000
PYTHON_ENV=development

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=appdb
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_MAX_MEMORY=256mb

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

JWT_SECRET=
JWT_EXPIRY=24h

DOMAIN_NAME=
